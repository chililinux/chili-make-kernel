debug() {
	#dialog
	whiptail --fb --clear --backtitle "[debug]$0" --title "[debug]$0" --yesno "${*}\n" 0 40
	local result="$?"
	((result)) && exit "$result"
	return "$result"
}

# ======================
# Usage
# ======================
usage() {
	echo -e "Usage: $0 [options]\n"
	echo "Options:"
	echo "  --nocolor          Disable color output"
	echo "  --verbose          Enable verbose output (full build logs)"
	echo "  --no-prepare       Skip preparation step"
	echo "  --no-build         Skip kernel build step"
	echo "  --no-build-docs    Skip docs build step"
	echo "  --no-kernel        Skip kernel installation"
	echo "  --no-headers       Skip headers installation"
	echo "  --no-slim          Skip slimming modules"
	echo "  --no-docs          Skip documentation installation"
	echo "  --no-initramfs     Skip create preset initramfs"
	echo "  -h, --help         Show this help message"
	exit 1
}

die() {
	printf "${red}${CROSS} ${red}fatal: %s\n${reset}" "$*"
	exit 1
}

sh_splitarray() {
	local str=("$1")
	local pos="$2"
	local sep="${3:-'|'}"
	local array

	[[ $# -eq 3 && "$pos" = "|" && "$sep" =~ ^[0-9]+$ ]] && {
		sep="$2"
		pos="$3"
	}
	[[ $# -eq 2 && "$pos" = "$sep" ]] && {
		sep="$pos"
		pos=1
	}
	[[ $# -eq 1 || ! "$pos" =~ ^[0-9]+$ ]] && { pos=1; }

	IFS="$sep" read -r -a array <<<"$str"
	echo "${array[pos - 1]}"
}

strtoarray() {
	local anew
	IFS=' ' read -r -a anew <<<"$1"
	echo "${anew[@]}"
}

lenarraystr() {
	local new=$1
	read -ra ADDR <<<"$new"
	echo "${#ADDR[@]}"
}

run_kernel() {
qemu-system-x86_64 \
  -enable-kvm \
  -cpu host \
  -smp $(nproc) \
  -m 2G \
  -kernel arch/x86/boot/bzImage \
  -initrd initrd.img
}

choose_setup() {
	local sep="\xe2\x94\x82"
	local sep="$(printf "$sep")"
	local xconfig

	xconfig=$(dialog \
		--colors \
		--stdout \
		--backtitle "$CCABEC" \
		--title " == SETUP ==" \
		--menu "Escolha o que quer fazer:" 0 0 0 \
		"Construir" "$sep Construir kernel" \
		"Testar"     "$sep Testar Kernel construido")

	exit_status=$?
	case $exit_status in
	"$D_ESC" | "$D_CANCEL")
		return 1
		;;
	esac
	SETUP_KERNEL="$xconfig"
	case $xconfig in
	  'Testar') run_kernel
	  choose_setup
	  ;;
	esac
}

choose_kernel() {
	local sep="\xe2\x94\x82"
	local sep="$(printf "$sep")"
	local xconfig

	xconfig=$(dialog \
		--colors \
		--stdout \
		--backtitle "$CCABEC" \
		--title " == KERNEL ==" \
		--radiolist "Escolha o modelo de configuração do kernel:" 0 0 0 \
		"config_customizado" "$sep Usa configurações de um arquivo pre-customizado" OFF \
		"config_atual" "$sep Copia a configuração do kernel em uso e atualiza para a versão nova. Kernel compatível e genérico" ON \
		"defconfig" "$sep Configuração padrão genérica para a arquitetura (ex.: x86). Kernel funcional, mas não otimizado" OFF \
		"olddefconfig" "$sep Atualiza config existente com defaults automáticos para novas opções" OFF \
		"localmodconfig" "$sep Kernel mínimo baseado nos módulos carregados. Kernel enxuto, adaptado ao hardware atual" OFF \
		"localyesconfig" "$sep Kernel monolítico, tudo embutido no kernel (sem módulos externos)." OFF \
		"alldefconfig" "$sep kernel mínimo padrão upstream" OFF \
		"allnoconfig" "$sep Kernel vazio, tudo desativado" OFF \
		"allyesconfig" "$sep Ativa praticamente todas as opções como built‑in. Kernel enorme, com tudo embutido" OFF \
		"allmodconfig" "$sep Ativa praticamente todas as opções como módulos. Kernel modular gigante." OFF)

	exit_status=$?
	case $exit_status in
	"$D_ESC" | "$D_CANCEL")
		return 1
		;;
	esac

	MOD_KERNEL="$xconfig"
	make_config "$MOD_KERNEL"
	if ! choose_config; then die "Cancelled!"; fi
}

choose_options() {
	local array=()
	local -A ARRAY=()
	local sep="\xe2\x94\x82"
	local xconfig

	ARRAY+=(['no-prepare']='Pular etapa de preparação|off')
	ARRAY+=(['no-build']='Pular etapa de compilação do kernel|off')
	ARRAY+=(['no-build-docs']='Pular etapa de compilação da documentação|on')
	ARRAY+=(['no-kernel']='Pular instalação do kernel|off')
	ARRAY+=(['no-headers']='Pular instalação dos headers|off')
	ARRAY+=(['no-slim']='Pular redução dos módulos|off')
	ARRAY+=(['no-docs']='Pular instalação da documentação|on')
	ARRAY+=(['no-initramfs']='Pular criação do preset initramfs|off')
	ARRAY+=(['nocolor']='Desativar saída colorida|off')
	ARRAY+=(['verbose']='Ativar saída detalhada (logs completos da compilação)|on')

	for key in $(printf "%s\n" "${!ARRAY[@]}" | sort); do
		option="${key}"
		desc=$(sh_splitarray "${ARRAY[$key]}" 1)
		flag=$(sh_splitarray "${ARRAY[$key]}" 2)
		array+=(
			"$option"
			"$(printf "$sep%-s" "$desc")"
			"$flag"
		)
	done

	xconfig=$($DIALOG \
		--colors \
		--backtitle "$CCABEC" \
		--default-item '' \
		--title "== PARÂMETROS ==" \
		--checklist "Escolha as parâmetros/flags" \
		--stdout \
		20 0 100 \
		"${array[@]}")

	exit_status=$?
	case $exit_status in
	"$D_ESC" | "$D_CANCEL")
		return 1
		;;
	esac
	OPTIONS=($(strtoarray "$xconfig"))
	# cria um novo array com prefixo --
	prefixed=()
	for opt in "${OPTIONS[@]}"; do
		prefixed+=(--"$opt")
	done
	GLOBAL_OPTS=("${prefixed[@]}")
}

choose_path() {
	local array=()
	local ARRAY=()
	local sep="\xe2\x94\x82"
	local xconfig

	#	mapfile -t ARRAY < <(find . -maxdepth 1 -type f -iname 'config-[0-9]*')
	#	if ((${#ARRAY[@]} == 0)); then
	#		die "Nenhum arquivo de configuração encontrado"
	#	fi
	ARRAY=("$HOME" /opt)

	if [[ $EUID -eq 0 ]]; then
		msg='Path'
	else
		msg='Caso você não tenha acesso para gravar, sera iniciado uma nova instanacia desse app, bastando escolher novamente o path'
	fi

	for key in "${ARRAY[@]}"; do
		filename=${key}
		array+=("$filename" "$(printf "$sep%-s" "$(file "$key")")")
	done

	xconfig=$(dialog \
		--default-item '' \
		--backtitle "$CCABEC" \
		--title "Escolha um diretorio de trabalho" \
		--stdout \
		--colors \
		--menu "$msg" \
		20 0 100 \
		"${array[@]}")

	exit_status=$?
	case $exit_status in
	"$D_ESC" | "$D_CANCEL")
		return 1
		;;
	esac
	rundir="$xconfig"
	echo "${rundir}"
}

choose_config() {
	local array=()
	local ARRAY=()
	local sep="\xe2\x94\x82"
	local xconfig

	mapfile -t ARRAY < <(find . -maxdepth 1 -type f -iname 'config-[0-9]*')
	if ((${#ARRAY[@]} == 0)); then
		die "Nenhum arquivo de configuração encontrado"
	fi

	for key in "${ARRAY[@]}"; do
		filename=${key##*/}
		array+=("$filename" "$(printf "$sep%-s" "$(file "$key")")")
	done
	xconfig=$(dialog \
		--default-item '$kernel_config' \
		--backtitle "$CCABEC" \
		--title "Escolha um Config" \
		--stdout \
		--colors \
		--menu "Configs's in $PWD" \
		20 0 100 \
		"${array[@]}")

	exit_status=$?
	case $exit_status in
	"$D_ESC" | "$D_CANCEL")
		return 1
		;;
	esac
	version="${xconfig#config-}"
	echo "${version}"
}

choose_kernel_tarball() {
	local array=()
	local ARRAY=()
	local sep="\xe2\x94\x82"
	local xconfig

	mapfile -t ARRAY < <(find . -maxdepth 1 -type f -iname 'linux*tar.xz')
	if ((${#ARRAY[@]} == 0)); then
		die "Nenhum tarball de kernel encontrado"
	fi

	for key in "${ARRAY[@]}"; do
		filename=${key##*/}
		array+=("$filename" "$(printf "$sep%-s" "$(file "$key")")")
	done
	xconfig=$(dialog \
		--default-item '' \
		--backtitle "$CCABEC" \
		--title "== TARBALL DE KERNEL ==" \
		--stdout \
		--colors \
		--menu "Tarball de Kernel's in $PWD" \
		20 0 100 \
		"${array[@]}")

	exit_status=$?
	case $exit_status in
	"$D_ESC" | "$D_CANCEL")
		return 1
		;;
	esac
	version="${xconfig#linux-}"
	version="${version%.tar.xz}"
	echo "${version}"
}

make_config() {
	local modelo="$1"

	case $modelo in
	config_atual)
		uname_r=$(uname -r)
		kconfig="config-${uname_r%_*}-custom"
		if [[ ! -e "$rundir/$kconfig" ]]; then
			zcat /proc/config.gz >"$rundir/$kconfig"
		fi
		;;
	*)
		choose_kernel_tarball
		kconfig="config-$version-$modelo"
		touch "$kconfig"
		;;
	esac
}

make_config_atual() {
	uname_r=$(uname -r)
	kconfig="config-${uname_r%_*}-custom"
	if [[ ! -e "$rundir/$kconfig" ]]; then
		zcat /proc/config.gz >"$rundir/$kconfig"
	fi
}

choose_version_type() {
	local array=()
	local ARRAY=("default" "versioned")
	local DESC=("vmlinuz-chili" "vmlinuz-$version")
	local sep="\xe2\x94\x82"
	local xversion
	local nc=0

	for key in "${ARRAY[@]}"; do
		filename=${key##*/}
		array+=("$filename" "$(printf "$sep%-s" "${DESC[nc]}")")
		((++nc))
	done
	xversion=$(dialog \
		--default-item '' \
		--backtitle "$CCABEC" \
		--title "Escolha um tipo" \
		--stdout \
		--colors \
		--menu "Tipos" \
		00 00 00 \
		"${array[@]}")

	exit_status=$?
	case $exit_status in
	"$D_ESC" | "$D_CANCEL")
		return 1
		;;
	esac
	version_type="${xversion}"
	case $version_type in
	default) versioned=false ;;
	versioned) versioned=true ;;
	esac
	echo "${version_type}"
}

run_cmd() {
	#	print_step "running: $*" "${black}"
	if $VERBOSE; then
		"$@" 2>&1 | tee -a "$localdir/build.log"
	else
		#		"$@" &>>build.log 2>&1
		#   "$@" >> build.log
		#   "$@" >> build.log 2>&1
		# stdout vai pro log, stderr vai pro terminal e pro log
		"$@" 1>>"$localdir/build.log" 2> >(tee -a "$localdir/build.log" >&2)
	fi
}
print_msg() {
	local msg="$1"
	local tempo="$2"
	local cor="${3:-${green}}"
	echo -e "${cor}${PREFIX:+$PREFIX }=== ${msg} (tempo decorrido: $tempo) ===${reset}"
}
print_title() {
	local msg="$1"
	local est="$2"
	local cor="${3:-${pink}}"
	echo -e "${cor}${PREFIX:+$PREFIX }=== ${msg} (estimativa: $est) ===${reset}"
}
print_step() {
	local msg="$1"
	local cor="${2:-${cyan}}"
	echo -e "${cor}${PREFIX:+$PREFIX }--> ${msg}${reset}"
}
print_done() {
	local msg="$1"
	local sec="$2"
	echo -e "${green}${PREFIX:+$PREFIX }✔ $msg (tempo real: ${sec}s)${reset}"
	echo
}
print_ok() {
	local msg="$1"
	echo -e "${green}${PREFIX:+$PREFIX }✔ ${msg}${reset}"
}
print_fail() {
	local msg="$1"
	echo -e "${RED}${PREFIX:+$PREFIX }✖ $msg${reset}"
}
print_warn() {
	local msg="$1"
	echo -e "${yellow}${PREFIX:+$PREFIX }⚠  $msg${reset}"
}

# ======================
# Funções
# ======================

fix_kernel_doc() {
	local kdoc="$builddir/$srcname/scripts/kernel-doc"

	print_step "Locaizando arquivo kernel-doc em Perl para correção"

	# só segue se existir
	[[ -f "$kdoc" ]] || {
		print_warn "kernel-doc não encontrado, nada a fazer"
		return 0
	}

	# testa se é Perl (shebang ou conteúdo)
	if head -n1 "$kdoc" | grep -q perl; then
		print_step "Corrigindo precedence bug no kernel-doc (Perl)"
		# Corrige todos os casos de "! $foo =~ regex" para "! ( $foo =~ regex )"
		run_cmd sed -i -E 's/!\s*\$([A-Za-z0-9_]+)\s*=~/!(\$\1 =~/g' "$kdoc"
		return 0
	else
		print_warn "kernel-doc é Python, nada a fazer"
	fi
}

patch_zram_block_shift() {
	local file="$builddir/$srcname/drivers/block/zram/zram_drv.h"

	print_step "Ajustando zram block em $file"
	run_cmd sudo sed -i '/^#define ZRAM_LOGICAL_BLOCK_SHIFT 12/{
    s/^/\/\/ /                             # comenta a linha
    a #define ZRAM_LOGICAL_BLOCK_SHIFT 9   /* 2^9 = 512B */
  }' "$file"
}

sh_wget_kernel() {
	local KERNEL="${srcname}.tar.xz"
	local major=$(echo "$KERNEL" | sed -E 's/^linux-([0-9]+).*/\1/') # Extrai a versão principal (ex: 6 -> v6.x)
	local URL="https://cdn.kernel.org/pub/linux/kernel/v${major}.x/$KERNEL"

	if [[ ! -f "${localdir}/${KERNEL}" ]]; then
		print_warn "Kernel $KERNEL não encontrado em ${localdir}, baixando..."
		if $VERBOSE; then
			run_cmd wget --continue "$URL" -O "${localdir}/${KERNEL}"
		else
			run_cmd wget --quiet --continue "$URL" -O "${localdir}/${KERNEL}"
		fi
	else
		print_ok "Kernel $KERNEL já está no diretório atual."
	fi

	# testando se existe agora
	if [[ ! -f "${localdir}/${KERNEL}" ]]; then
		return 1
	fi
	return 0
}

prepare() {
	local start=$SECONDS

	PREFIX="[PREPARE]"
	print_title "Preparando kernel ($ARCH)" "1 min"

	if ! sh_wget_kernel; then
		die "Kernel source $localdir/${srcname}.tar.xz não encontrado em $localdir"
		exit 1
	fi

	run_cmd sudo rm -rfv "$builddir"
	run_cmd mkdir -p "$builddir"

	[[ ! -f "$source_tarball" ]] && {
		print_fail "Source tarball não encontrado: $source_tarball"
		exit 1
	}

	run_cmd tar -xvJf "$source_tarball" -C "$builddir"
	cd "$builddir/$srcname"

	[[ ! -f "$kernel_config" ]] && {
		print_fail "Arquivo de configuração não encontrado: $kernel_config"
		exit 1
	}

	case $MOD_KERNEL in
	alldefconfig)
		print_step "Running make alldefconfig"
		run_cmd make -j"$(nproc)" mrproper
		run_cmd make -j"$(nproc)" alldefconfig
		cp .config "$kernel_config"
		print_step "Copied .config to $kernel_config"
		;;
	defconfig)
		print_step "Running make defconfig"
		run_cmd make defconfig
		cp .config "$kernel_config"
		print_step "Copied .config to $kernel_config"
		;;
	localyesconfig)
		print_step "Running make localyesconfig"
		run_cmd make olddefconfig
		run_cmd make localyesconfig
		cp .config "$kernel_config"
		print_step "Copied .config to $kernel_config"
		;;
	config_customizado | config_atual)
		cp "$kernel_config" .config
		print_step "Copied .config from $kernel_config"
		print_step "Running make olddefconfig"
		run_cmd make olddefconfig
		#cd "$builddir/$srcname"
		#fix_kernel_doc
		;;
	esac

	cd "$builddir/$srcname"
	patch_zram_block_shift

	print_done "Kernel preparado" $((SECONDS - start))
}

fix_kernel_config() {
	local start=$SECONDS

	PREFIX="[CONFIG]"

	print_title "Ajustando configuração do kernel" "1 min"
	run_cmd scripts/config --enable CONFIG_BLK_DEV_INITRD
  run_cmd scripts/config --set-str CONFIG_INITRAMFS_SOURCE ""
	run_cmd scripts/config --enable CONFIG_RD_GZIP
	run_cmd scripts/config --enable CONFIG_RD_BZIP2
	run_cmd scripts/config --enable CONFIG_RD_LZMA
	run_cmd scripts/config --enable CONFIG_RD_XZ
	run_cmd scripts/config --enable CONFIG_RD_LZO
	run_cmd scripts/config --enable CONFIG_RD_LZ4
	run_cmd scripts/config --enable CONFIG_RD_ZSTD
	run_cmd scripts/config --enable ACPI_TABLE_UPGRADE

	run_cmd scripts/config --enable CONFIG_INITRAMFS_PRESERVE_MTIME

	run_cmd scripts/config --enable CONFIG_EXT4_FS
	run_cmd scripts/config --enable CONFIG_EXT4_USE_FOR_EXT2
	run_cmd scripts/config --enable CONFIG_EXT4_FS_POSIX_ACL
	run_cmd scripts/config --enable CONFIG_EXT4_FS_SECURITY
	run_cmd scripts/config --enable CONFIG_EXT4_DEBUG

	run_cmd scripts/config --enable CONFIG_JBD2
	run_cmd scripts/config --enable CONFIG_JBD2_DEBUG

	run_cmd scripts/config --enable CONFIG_DEVTMPFS
	run_cmd scripts/config --enable CONFIG_DEVTMPFS_MOUNT
	run_cmd scripts/config --enable CONFIG_DEVTMPFS_SAFE

	run_cmd scripts/config --enable CONFIG_XZ_DEC
	run_cmd scripts/config --enable CONFIG_XZ_DEC_MICROLZMA
	run_cmd scripts/config --enable CONFIG_XZ_DEC_TEST

	print_step "Habilitando suporte a initramfs"
	run_cmd scripts/config --enable CONFIG_BLK_DEV_INITRD
	run_cmd scripts/config --enable BLK_DEV_INITRD

	print_step "Habilitando suporte a ext4"
	run_cmd scripts/config --enable CONFIG_EXT4_FS
	run_cmd scripts/config --enable CONFIG_EXT4_USE_FOR_EXT2
	run_cmd scripts/config --enable CONFIG_JBD2
	run_cmd scripts/config --enable CONFIG_VIRTIO_BLK
	run_cmd scripts/config --enable CONFIG_DEVTMPFS
	run_cmd scripts/config --enable CONFIG_DEVTMPFS_MOUNT
	run_cmd scripts/config --enable CONFIG_VIRTIO
	run_cmd scripts/config --enable CONFIG_VIRTIO_BLK
	run_cmd scripts/config --enable CONFIG_VIRTIO_PCI

	print_done "Configuração atualizada" $((SECONDS - start))
	PREFIX=""
}

build() {
	local start=$SECONDS

	PREFIX='[BUILD]'
	cd "$builddir/$srcname"

	fix_kernel_config

	print_title "Compilando kernel e módulos ($ARCH)" "30 min"
	#	run_cmd make -j"$(nproc)" ARCH="$ARCH" all
	#	run_cmd make -j"$(nproc)" all
	run_cmd make -j"$(nproc)" bzImage modules
	print_done "Kernel e módulos compilados" $((SECONDS - start))

	local start_bpf=$SECONDS
	print_title "Gerando headers BPF CO-RE" "2 min"
	#	run_cmd make -C tools/bpf/bpftool ARCH="$ARCH" vmlinux.h feature-clang-bpf-co-re=1
	if grep -q '^CONFIG_DEBUG_INFO_BTF=y' .config; then
		run_cmd make -C tools/bpf/bpftool vmlinux.h feature-clang-bpf-co-re=1
	else
		print_step "[BUILD] BTF não disponível, pulando geração do vmlinux.h"
	fi
	print_done "BPF headers gerados" $((SECONDS - start_bpf))
}

build_docs() {
	local start_docs=$SECONDS

	PREFIX='[BUILD-DOCS]'
	cd "$builddir/$srcname"

	print_title "Gerando documentação HTML" "2 min"
	#	run_cmd make ARCH="$ARCH" htmldocs SPHINXOPTS=-QT
	run_cmd make htmldocs SPHINXOPTS="-QT -j4"
	print_done "Docs gerados" $((SECONDS - start_docs))
}

install_kernel() {
	local start=$SECONDS
	local modulesdir="$pkgdir_kernel/usr/lib/modules/$version"
	local vmlinuz_boot="vmlinuz-$version"
	local vmlinuz_dest="$modulesdir/$vmlinuz_boot"
	local pkgdir_kernel="$localdir/modules-$pkgbase"

	run_cmd sudo rm -rvf "$pkgdir_kernel"
	run_cmd mkdir -p "$pkgdir_kernel"
	run_cmd mkdir -p "$modulesdir"

	cd "$builddir/$srcname"

	PREFIX='[KERNEL]'
	print_title "Instalando vmlinuz e módulos ($ARCH)" "3 min"

	# Copia para a árvore do pacote
	print_step "Instalando vmlinuz em: $vmlinuz_dest"
	run_cmd install -Dm644 "$(make -s image_name)" "$vmlinuz_dest"

	print_step "Instalando vmlinuz em: $pkgdir_kernel/boot/$vmlinuz_boot"
	run_cmd install -Dm644 "$(make -s image_name)" "$pkgdir_kernel/boot/$vmlinuz_boot"

	# pkgbase
	echo "$pkgbase" | run_cmd install -Dm644 /dev/stdin "$modulesdir/pkgbase"
	print_step "pkgbase instalado"

	# Instala módulos
	print_step "Strip + install modules"
	#	ZSTD_CLEVEL=19 run_cmd make ARCH="$ARCH" INSTALL_MOD_PATH="$pkgdir_kernel/usr" INSTALL_MOD_STRIP=1 modules_install
	ZSTD_CLEVEL=19 run_cmd make -j$(nproc) INSTALL_MOD_PATH="$pkgdir_kernel/usr" INSTALL_MOD_STRIP=1 modules_install

	print_step "Removendo link do build em: $modulesdir"
	run_cmd rm -fv "$modulesdir/build"

	print_done "Kernel e módulos instalados" $((SECONDS - start))
}

install_headers() {
	case $distro in
	void) install_headers_void ;;
	*) install_headers_generic ;;
	esac
}

install_headers_void() {
	local start=$SECONDS
	local src="$builddir/$srcname"
	local dst="$pkgdir_headers/usr/lib/modules/$version/build"

	PREFIX="[HEADERS]"

	run_cmd rm -rf "$pkgdir_headers"
	run_cmd mkdir -p "$dst"

	print_title "Instalando linux-headers (Void style)" "2 min"

	cd "$src"

	# prepara árvore para módulos externos
	print_step "Executando modules_prepare"
	run_cmd make modules_prepare

	# copia árvore essencial
	print_step "Copiando árvore de headers"

	(
		cd "$src" && tar cf - \
			Makefile \
			.config \
			System.map \
			include \
			scripts \
			arch/x86
	) | (cd "$dst" && tar xf -)

	# arquivos opcionais
	print_step "Copiando arquivos opcionais"

	[ -f Module.symvers ] && cp -a Module.symvers "$dst/"
	[ -f vmlinux ] && cp -a vmlinux "$dst/"

	# remove arquiteturas não usadas
	print_step "Removendo arquiteturas desnecessárias"

	find "$dst/arch" -mindepth 1 -maxdepth 1 ! -name x86 -exec rm -rf {} +

	# remove documentação
	run_cmd rm -rf "$dst/Documentation"

	# remove objetos temporários
	find "$dst" -name '*.o' -delete

	# remove symlinks quebrados
	find -L "$dst" -type l -delete

	# cria symlink padrão
	print_step "Criando symlink em /usr/src"

	mkdir -p "$pkgdir_headers/usr/src"
	run_cmd ln -sfr "$dst" "$pkgdir_headers/usr/src/linux-$version"

	print_done "Headers instalados (Void style)" $((SECONDS - start))
	PREFIX=""
}

install_headers_generic() {
	local start=$SECONDS
	local src="$builddir/$srcname"
	local dst="$pkgdir_headers/usr/lib/modules/$version/build"

	PREFIX="[HEADERS]"

	run_cmd sudo rm -rfv "$pkgdir_headers"
	run_cmd mkdir -p "$dst"

	print_title "Instalando headers e scripts de build" "5 min"

	cd "$src"

	# prepara árvore para módulos externos
	print_step "Executando modules_prepare"
	run_cmd make modules_prepare

	# copia árvore principal (rápido e preserva tudo)
	print_step "Copiando árvore de headers"

	(
		cd "$src" && tar cf - \
			Makefile \
			.config \
			System.map \
			include \
			scripts \
			arch
	) | (cd "$dst" && tar xf -)

	# arquivos opcionais
	print_step "Instalando arquivos opcionais"

	[ -f Module.symvers ] &&
		run_cmd install -Dm644 Module.symvers "$dst/Module.symvers"

	[ -f vmlinux ] &&
		run_cmd install -Dm644 vmlinux "$dst/vmlinux"

	[ -f tools/bpf/bpftool/vmlinux.h ] &&
		run_cmd install -Dm644 tools/bpf/bpftool/vmlinux.h "$dst/vmlinux.h"

	# ferramentas usadas por módulos externos
	print_step "Instalando ferramentas"

	if [ -f tools/objtool/objtool ]; then
		run_cmd install -Dm755 tools/objtool/objtool \
			"$dst/tools/objtool/objtool"
	fi

	if [ -f tools/bpf/resolve_btfids/resolve_btfids ]; then
		run_cmd install -Dm755 tools/bpf/resolve_btfids/resolve_btfids \
			"$dst/tools/bpf/resolve_btfids/resolve_btfids"
	fi

	# vdso (compatível com kernels antigos)
	if make -q vdso_install 2>/dev/null; then
		print_step "Instalando VDSO"
		run_cmd make INSTALL_MOD_PATH="$pkgdir_headers/usr" vdso_install link=
	fi

	# remover arquiteturas não usadas
	print_step "Removendo arquiteturas desnecessárias"

	local arch
	for arch in "$dst"/arch/*; do
		[[ "$arch" == */x86 ]] && continue
		run_cmd rm -rf "$arch"
	done

	# remover documentação pesada
	run_cmd rm -rf "$dst/Documentation"

	# remover objetos de build
	find "$dst" -type f -name '*.o' -delete

	# remover symlinks quebrados
	find -L "$dst" -type l -delete

	# strip em ferramentas
	print_step "Stripando ferramentas"

	while IFS= read -r -d '' f; do
		case "$(file -Sib "$f")" in
		application/x-executable* | application/x-sharedlib*)
			strip "$f"
			;;
		esac
	done < <(find "$dst" -type f -perm -u+x ! -name vmlinux -print0)

	# symlink final
	print_step "Criando symlink"

	mkdir -p "$pkgdir_headers/usr/src"
	run_cmd ln -sfr "$dst" "$pkgdir_headers/usr/src/$pkgbase_headers"

	# remover lixo
	find "$dst" -name ".gitignore" -delete

	print_done "Headers instalados" $((SECONDS - start))
	PREFIX=""
}

slim_modules() {
	local start=$SECONDS
	local modulesdir="$pkgdir_kernel/usr/lib/modules/$version"

	PREFIX='[SLIM]'
	print_title "Limpando módulos desnecessários" "3 min"

	# Remove arquiteturas que não são a usada
	for archdir in "$modulesdir"/arch/*/; do
		[[ $(basename "$archdir") == "$ARCH" ]] && continue
		print_step "Removing $(basename "$archdir")"
		rm -rf "$archdir"
	done

	# Remove documentação do kernel
	rm -rf "$modulesdir/Documentation"
	print_step "Removed Documentation/"

	# Remove objetos .o
	find "$modulesdir" -type f -name '*.o' -print -delete

	# Strip apenas ELF (sharedlibs, archives, executables)
	while IFS= read -rd '' file; do
		case "$(file -Sib "$file")" in
		application/x-sharedlib\;* | application/x-archive\;* | application/x-executable\;* | application/x-pie-executable\;*)
			strip -v "$file"
			;;
		esac
	done < <(find "$modulesdir" -type f -perm -u+x -print0)

	# NÃO stripar o vmlinuz (já vem comprimido)
	print_step "Mantido vmlinuz intacto"

	# symlink para /usr/src
	mkdir -p "$pkgdir_kernel/usr/src"
	ln -sfr "$modulesdir" "$pkgdir_kernel/usr/src/$pkgbase"
	print_step "Created symlink $pkgdir_kernel/usr/src/$pkgbase -> $modulesdir"

	print_done "Slim módulos concluído" $((SECONDS - start))
}

install_docs() {
	local start=$SECONDS
	cd "$builddir/$srcname"

	PREFIX="[DOCS]"
	print_title "Instalando documentação" "1 min"

	# Copia tudo que foi gerado pelo 'make htmldocs'
	local docsrc="Documentation/output"
	local docdst="$pkgdir_docs/usr/lib/modules/$version/Documentation"

	if [[ ! -d "$docsrc" ]]; then
		print_fail "Documentação HTML não encontrada em $docsrc"
		exit 1
	fi

	run_cmd mkdir -p "$docdst"
	run_cmd cp -a "$docsrc/." "$docdst/"
	print_step "Docs copiados para $docdst"

	print_done "Docs instalados" $((SECONDS - start))
}

sh_create_initramfs() {
	case $distro in
	arch)
		create_mkinitcpio_preset
		;;
	void)
		create_dracut_config
		create_void_trigger
		;;
	esac
}

create_dracut_config() {
	local dracutdir="$pkgdir_kernel/etc/dracut.conf.d"
	local cfg="$dracutdir/chili.conf"

	mkdir -p "$dracutdir"

	cat <<EOF >"$cfg"
hostonly=yes
compress="zstd"
EOF
}

create_void_trigger() {
	local trig="$pkgdir_kernel/usr/libexec/xbps-triggers/kernel"

	mkdir -p "$(dirname "$trig")"

	cat <<EOF >"$trig"
#!/bin/sh
dracut --force --kver $version
EOF

	chmod +x "$trig"
}

create_mkinitcpio_preset() {
	local start=$SECONDS
	local presetdir="$pkgdir_kernel/etc/mkinitcpio.d"
	local presetfile="$presetdir/chili-$version.preset"

	PREFIX="[MKINITCPIO]"

	# Cria diretório se não existir
	run_cmd sudo mkdir -p "$presetdir"

	print_title "Criando arquivo preset $presetfile" "1 min"

	# Gera arquivo preset
	cat <<EOF | run_cmd sudo tee "$presetfile" >/dev/null
# mkinitcpio preset file for the '$pkgbase' package

#PRESETS=('default' 'fallback')
#PRESETS=('default' 'iso')
PRESETS=('default')

ALL_kver="/boot/vmlinuz-\${_VERSION}"
ALL_config="/etc/mkinitcpio.conf"

#default_config="/etc/mkinitcpio.conf"
default_image="/boot/initrd-\${_VERSION}.img"
#default_options=""

iso_config="/etc/mkinitcpio-iso.conf"
iso_image="/boot/initrd-\${_VERSION}-iso.img"

#fallback_config="/etc/mkinitcpio.conf"
fallback_image="/boot/initramfs-linux-\${_VERSION}-fallback.img"
fallback_options="-S autodetect"
EOF

	print_done "Preset mkinitcpio criado em $presetfile" $((SECONDS - start))
	PREFIX=""
}

create_hook() {
	local start=$SECONDS
	local hookdir="/usr/share/libalpm/hooks"
	local hookfilefile

	PREFIX="[HOOK]"
	print_title "Criando arquivo hook" "1 min"

	# Cria diretório se não existir
	run_cmd sudo mkdir -p "${hookdir}"
	run_cmd sudo mkdir -p "${pkgdir_kernel}/${hookdir}"

	# Gera arquivo hook
	if ! $versioned; then
		hookfile="${hookdir}/chili-linux-install.hook"
		cat <<EOF | run_cmd sudo tee "$pkgdir_kernel/$hookfile" >/dev/null
[Trigger]
Type      = Package
Operation = Install
Operation = Upgrade
#Operation = Remove
Target    = chili-linux
Target    = chili-linux-headers

[Trigger]
Type      = Path
Operation = Install
Operation = Upgrade
Target    = /usr/lib/modules/chili/vmlinuz*

[Action]
Description = ==>[chili-linux] Updating linux initcpios...
When        = PostTransaction
Exec        = /bin/bash -c '/usr/bin/mkinitcpio -p chili && /usr/bin/update-grub'
EOF
	else
		hookfile="${hookdir}/chili-linux-$version-install.hook"
		cat <<EOF | run_cmd sudo tee "$pkgdir_kernel/$hookfile" >/dev/null
[Trigger]
Type      = Package
Operation = Install
Operation = Upgrade
#Operation = Remove
Target    = chili-linux-$version
Target    = chili-linux-headers-$version

[Trigger]
Type      = Path
Operation = Install
Operation = Upgrade
Target    = /usr/lib/modules/$version/vmlinuz*

[Action]
Description = ==>[chili-linux-$version] Updating linux initcpios...
When        = PostTransaction
Exec        = /bin/bash -c '/usr/bin/mkinitcpio -p chili-$version && /usr/bin/update-grub'
EOF
	fi

	print_done "Hook criado em $hookfile" $((SECONDS - start))
	PREFIX=""
}

print_elapsed() {
	local elapsed=$((SECONDS - start_global))
	local hours=$((elapsed / 3600))
	local minutes=$(((elapsed % 3600) / 60))
	local seconds=$((elapsed % 60))
	local decorrido="$(printf "%dh %dm %ds\n" "$hours" "$minutes" "$seconds")"

	# imprime no terminal
	echo -e "$decorrido"

	# grava no build.log
	echo -e "Tempo decorrido: $decorrido" >>"$localdir/build.log"
}

install_package() {
	local start=$SECONDS
	local modules_dir="$localdir/modules-linux-$version"
	local headers_dir="$localdir/headers-linux-$version"
	local package_dir="$localdir/package-linux-$version"

	if ! $versioned; then
		package_dir="$localdir/package-linux"
	fi

	run_cmd cd "$localdir"

	# Verificar se pastas existem
	for d in "$modules_dir" "$headers_dir"; do
		if [ ! -d "$d" ]; then
			print_fail "Erro: diretório $d não encontrado!"
			exit 1
		fi
	done

	# Criar destino limpo
	run_cmd sudo rm -rf "$package_dir"
	run_cmd mkdir -p "$package_dir/modules"
	run_cmd mkdir -p "$package_dir/headers"

	# Copiar conteúdo preservando estrutura
	print_step "[*] Copiando modules..."
	rsync -a "$modules_dir"/ "$package_dir/modules"/

	print_step "[*] Copiando headers..."
	rsync -a "$headers_dir"/ "$package_dir/headers"/

	# Remover arquivos inúteis de git
	print_step "[*] Limpando lixo '(.gitignore, .gitkeep, etc)'..."
	run_cmd find "$package_dir" -type f \( -name ".gitignore" -o -name ".gitkeep" -o -name ".gitattributes" \) -delete

	print_step "[*] Removendo $package_dir/headers/usr/lib/modules/$version/build/vmlinux"
	run_cmd rm -fv "$package_dir/headers/usr/lib/modules/$version/build/vmlinux"

	if ! $versioned; then
		print_step "[*] Ajustando arquivos para versão 'default'..."
		run_cmd mv -fv "$package_dir/modules/boot/vmlinuz-$version" "$package_dir/modules/boot/vmlinuz-chili-linux"

		print_step "[*] Removendo $package_dir/modules/etc/mkinitcpio.d/chili-$version"
		run_cmd rm -fv "$package_dir/modules/etc/mkinitcpio.d/chili-$version.preset"

		print_step "Gerando arquivo preset"
		cat <<EOF | run_cmd tee "$package_dir/modules/etc/mkinitcpio.d/chili.preset" >/dev/null
# mkinitcpio preset file for the '$pkgbase' package

PRESETS=('default' 'fallback')
#PRESETS=('default')

ALL_config="/etc/mkinitcpio.conf"
ALL_kver="/boot/vmlinuz-chili-linux"

#default_config="/etc/mkinitcpio.conf"
default_image="/boot/initrd-chili-linux.img"
#default_options=""

#fallback_config="/etc/mkinitcpio.conf"
fallback_image="/boot/initrd-chili-linux-fallback.img"
fallback_options="-S autodetect"
EOF

		hookdir="$package_dir/modules/usr/share/libalpm/hooks"
		hookfile="${hookdir}/chili-linux-install.hook"

		print_step "[*] Removendo $hookdir/*.preset"
		run_cmd rm -fv "$hookdir/*.preset"

		print_step "Gerando arquivo hook"
		cat <<EOF | run_cmd tee "$hookfile" >/dev/null
[Trigger]
Type      = Package
Operation = Install
Operation = Upgrade
#Operation = Remove
Target    = chili-linux
Target    = chili-linux-headers

[Trigger]
Type      = Path
Operation = Install
Operation = Upgrade
Target    = /usr/lib/modules/chili/vmlinuz*

[Action]
Description = ==>[chili-linux] Updating linux initcpios...
When        = PostTransaction
Exec        = /bin/bash -c '/usr/bin/mkinitcpio -p chili && /usr/bin/update-grub'
EOF
	fi

	print_step "[*] Criando link em $package_dir..."
	run_cmd pushd "$package_dir/modules/usr/lib/modules/"
	run_cmd ln -sf "$version" "chili"
	run_cmd popd

	print_step "[*] Alterando permissoes em $package_dir..."
	run_cmd sudo chown root:root "$package_dir/" -R

	print_done "[✓] Pacote gerado em: $package_dir" $((SECONDS - start))

}

sh_checkroot() {
	((EUID != 0)) && elevate_to_root "$@" || return 0
}

elevate_to_root() {
	print_ok "This script must be run as root. Elevating privileges..."
	CCABEC+='root [elevated]'
	# Tenta usar sudo primeiro (caso esteja configurado)
	if command -v sudo >/dev/null 2>&1; then
		exec sudo bash "$0" "$@"
	fi
	# Se sudo falhar, tenta su
	if command -v su >/dev/null 2>&1; then
		exec su -c "$0 $*"
	fi
	die "Error: Unable to elevate privileges. Run manually as root."
}

# uso dentro do app:
#run_as_root cp arquivo /opt/meuapp/
run_as_root() {
	if [[ $EUID -eq 0 ]]; then
		"$@"
	else
		pkexec "$@"
	fi
}

get_distro() {
	if [[ -f /etc/os-release ]]; then
		. /etc/os-release
		DISTRO="$ID"
	else
		DISTRO="unknown"
	fi
	echo "$DISTRO"
}

distro="$(get_distro)"
CCABEC+="${GREEN} - running on $distro"

choose_setup
if ! choose_options; then die "Cancelled!"; fi
set -- "${GLOBAL_OPTS[@]}" # definido em choose_options()
echo "$@"

# ======================
# Parse parameters
# ======================
while [[ $# -gt 0 ]]; do
	case "$1" in
	--nocolor) COLOR=0 ;;
	--verbose) VERBOSE=true ;;
	--no-prepare) DO_PREPARE=false ;;
	--no-build) DO_BUILD=false ;;
	--no-build-docs) DO_BUILD_DOCS=false ;;
	--no-kernel) DO_INSTALL_KERNEL=false ;;
	--no-headers) DO_INSTALL_HEADERS=false ;;
	--no-slim) DO_SLIM_MODULES=false ;;
	--no-docs) DO_INSTALL_DOCS=false ;;
	--no-initramfs) DO_CREATE_INITRAMFS=false ;;
	--no-hook) DO_CREATE_HOOK=false ;;
	--no-package) DO_PACKAGE=false ;;
	-h | --help) usage ;;
	*)
		echo "Unknown option: $1"
		usage
		;;
	esac
	shift
done

# ======================
# Configuração principal
# ======================
#version='6.12.43-lts-chili'
#version=type='versioned'
#versioned=true
rundir=''
if ! choose_path; then die "Cancelled!"; fi
if [ ! -w "$rundir" ]; then
	elevate_to_root "$@"
fi
rundir+='/chili-make-kernel/build'
mkdir -p "$rundir"
pushd "${rundir}" || die

#uname_r=$(uname -r)
#kconfig="config-${uname_r%_*}-custom"
#if [[ ! -e "$kconfig" ]]; then
#	zcat /proc/config.gz >"$rundir/$kconfig"
#fi

if ! choose_kernel; then die "Cancelled!"; fi
if ! choose_version_type; then die "Cancelled!"; fi

pkgbase="linux-$version"
pkgbase_headers="linux-headers-$version"
ARCH="x86_64"
localdir="$rundir"
builddir="$localdir/build-$pkgbase"
pkgdir_kernel="$localdir/modules-$pkgbase"
pkgdir_headers="$localdir/headers-$pkgbase"
pkgdir_docs="$localdir/docs-$pkgbase"
srcname="linux-${version%%-*}"
#kernel_config="$localdir/config"
kernel_config="$localdir/config-${version}"
source_tarball="$localdir/${srcname}.tar.xz"
mkdir -p "$builddir" "$pkgdir_kernel" "$pkgdir_headers" "$pkgdir_docs"

# ======================
# Fluxo principal
# ======================
$DO_PREPARE && prepare
$DO_BUILD && build
$DO_BUILD_DOCS && build_docs
$DO_INSTALL_KERNEL && install_kernel
$DO_INSTALL_HEADERS && install_headers
$DO_SLIM_MODULES && slim_modules
$DO_INSTALL_DOCS && install_docs
$DO_CREATE_INITRAMFS && sh_create_initramfs
$DO_CREATE_HOOK && create_hook
$DO_PACKAGE && install_package

PREFIX="[FINAL]"
print_msg "Kernel $version ($pkgbase) buildado e instalado" "$(print_elapsed)" "${azul}"
