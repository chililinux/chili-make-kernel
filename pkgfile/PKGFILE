pkgname=chili-make-kernel
pkgdesc="Suite de scripts para construção automatica de kernel Linux customizado"
pkgver=$(date +%Y%m%d)
pkgrel=$(date +%H%M)
arch=('any')
license=('MIT')
#url="ssh://git@github.com/chililinux/${pkgname}"
url="https://github.com/chililinux/${pkgname}"
source=("git+${url}.git")
md5sums=('SKIP')
depends=(pahole pahole-devel python3-yaml graphviz)
optdepends=()

package() {
	cd "${srcdir}/${pkgname}"

	# Verify default folder
	if [ -d "${srcdir}/${pkgname}/${pkgname}" ]; then
		InternalDir="${srcdir}/${pkgname}/${pkgname}"
	else
		InternalDir="${srcdir}/${pkgname}"
	fi

	# Copiar a estrutura de /etc, /usr e /opt para /
	local dirs=("usr" "etc" "opt" "boot" "build")
	for dir in "${dirs[@]}"; do
		if [ -d "${InternalDir}/${dir}" ]; then
			cp -a "${InternalDir}/${dir}" "${pkgdir}/"
		fi
	done

	# Install license file if present
	if [ -f "LICENSE" ]; then
		install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
	fi

	# Install documentation if present
	if [ -f "README.md" ]; then
		install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
	fi
}
